# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Auth ─────────────────────────────────────────────────────────────────────
# Any non-empty string is accepted by gorest.in for write operations
# Use "blocked-token" to intentionally trigger 403 Forbidden
BEARER_TOKEN=demo-token
BEARER_BLOCKED_TOKEN=blocked-token

# ── Environment override (optional) ──────────────────────────────────────────
# Overrides api_env in pytest.ini. Values: dev | staging | prod
# API_ENV=dev

# ── URL override (optional) ──────────────────────────────────────────────────
# API_BASE_URL=https://gorest.in

# ── Timeouts (optional) ──────────────────────────────────────────────────────
# API_TIMEOUT=30
# API_VERIFY_SSL=true

# ── Test Reporting Server (optional) ─────────────────────────────────────────
# REPORT_ENABLED must be explicitly set to "true" to push test results to the
# reporting server below. If it's missing, or anything other than true/1/yes,
# reporting is skipped — even if the other REPORT_* values are set. This lets
# you keep REPORT_SERVER_URL/PROJECT_ID/SERVICE_TOKEN in place and flip just
# this one value to turn reporting on/off.
# REPORT_ENABLED=true
# REPORT_SERVER_URL=https://api.dev.report.subodhsingh.in
# REPORT_PROJECT_ID=1
# REPORT_SERVICE_TOKEN=your-service-token
